{
	"name": "@lightbase/rn-design-system",
	"version": "2.8.0-alpha.5",
	"description": "Lightbase internal react native design system",
	"source": "./src/index.ts",
	"main": "./src/index.ts",
	"module": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./config": {
			"types": "./src/config/index.ts",
			"default": "./src/config/index.ts"
		},
		"./package.json": "./package.json",
		"./app.plugin.js": "./app.plugin.js"
	},
	"files": [
		"src",
		"lib/commonjs/expo*",
		"android",
		"ios",
		"cpp",
		"app.plugin.js",
		"*.podspec",
		"!ios/build",
		"!android/build",
		"!android/gradle",
		"!android/gradlew",
		"!android/gradlew.bat",
		"!android/local.properties",
		"!**/__tests__",
		"!**/__fixtures__",
		"!**/__mocks__",
		"!**/.*"
	],
	"scripts": {
		"test": "jest",
		"typecheck": "tsc --noEmit",
		"check": "npx @biomejs/biome check ./ --write",
		"prepare": "tsc src/expo.ts --outDir lib/commonjs --module commonjs --esModuleInterop --target ES2022 --skipLibCheck --resolveJsonModule --moduleResolution node",
		"release": "release-it",
		"updates": "npx npm-check-updates -i"
	},
	"keywords": [
		"react-native",
		"ios",
		"android"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lightbasenl/rn-design-system.git"
	},
	"author": "Oliver Winter <owinter86@gmail.com> (https://github.com/owinter86)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/lightbasenl/rn-design-system/issues"
	},
	"homepage": "https://github.com/lightbasenl/rn-design-system#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"dependencies": {
		"@capsizecss/core": "4.1.3",
		"@ctrl/tinycolor": "4.2.0",
		"mime": "^3.0.0",
		"opentype.js": "1.3.4",
		"react-keyed-flatten-children": "5.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@expo/config-plugins": "~55.0.5",
		"@react-navigation/bottom-tabs": "7.9.0",
		"@react-navigation/elements": "2.9.3",
		"@react-navigation/native": "7.1.26",
		"@react-navigation/native-stack": "7.9.0",
		"@release-it/conventional-changelog": "10.0.6",
		"@types/mime": "^3.0.4",
		"@types/opentype.js": "1.3.9",
		"@types/react": "~19.2.14",
		"babel-plugin-module-resolver": "5.0.3",
		"expo": "~55.0.8",
		"expo-module-scripts": "^55.0.2",
		"react": "19.2.0",
		"react-native": "0.83.2",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-keyboard-controller": "1.20.7",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-unistyles": "^3.1.1",
		"release-it": "19.2.4",
		"typescript": "~5.9.3"
	},
	"peerDependencies": {
		"@react-navigation/bottom-tabs": "*",
		"@react-navigation/elements": "*",
		"@react-navigation/native": "*",
		"@react-navigation/native-stack": "*",
		"react": "*",
		"react-native": "*",
		"react-native-keyboard-controller": "*",
		"react-native-reanimated": "*",
		"react-native-safe-area-context": "*",
		"react-native-gesture-handler": "*",
		"react-native-unistyles": "^3.0.0"
	},
	"engines": {
		"node": ">= 22.15.0"
	},
	"create-react-native-library": {
		"languages": "js",
		"type": "library",
		"version": "0.50.3"
	}
}
